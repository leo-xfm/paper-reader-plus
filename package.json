{
  "name": "paper-reader-plus",
  "version": "0.2.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-builder install-app-deps",
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "start": "electron .",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "codemirror": "^6.0.2",
    "jszip": "^3.10.1",
    "katex": "^0.16.46",
    "lucide-vue-next": "^0.511.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.15.0",
    "pdfjs-dist": "4.10.38",
    "pinia": "^3.0.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "37.10.3",
    "electron-builder": "25.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.6",
    "vue-tsc": "^2.2.10",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.paperreader.plus",
    "productName": "Paper Reader Plus",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "docs/*.j2",
      "docs/*.md",
      "docs/*.json",
      "icon/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "docs",
        "to": "docs",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "fonts",
        "to": "fonts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "icon": "icon/256.png",
    "win": {
      "icon": "icon/256.png",
      "target": "nsis"
    },
    "mac": {
      "icon": "icon/256.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "en_US",
        "zh_CN"
      ]
    },
    "fileAssociations": [
      {
        "ext": "readerp",
        "name": "ReaderP Package",
        "description": "Paper Reader Plus ReaderP Package",
        "role": "Editor"
      },
      {
        "ext": "readerm",
        "name": "ReaderM Package",
        "description": "Paper Reader Plus ReaderM Package",
        "role": "Editor"
      },
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Paper Reader Plus Markdown Document",
        "role": "Editor"
      }
    ]
  }
}
